# Application Mode: 'test' or 'live'
APP_MODE=test

# Launch mode:
# - selection (default): show mode selection page
# - kiosk | large_kiosk | pos | mobile_kiosk: launch directly in that mode
KIOSK_FIXED_MODE=selection

# Release build controls (used by ./build_release.sh)
BUILD_RELEASE_AUTO_INCREMENT=true
BUILD_RELEASE_ALL_APKS=true
BUILD_RELEASE_DEFAULT_MODE=kiosk
BUILD_RELEASE_OUTPUT_DIR=release_apks
BUILD_RELEASE_NAME_PREFIX=megapos
AUTO_CREATE_RELEASE_KEYSTORE=true
RELEASE_KEYSTORE_PATH=android/app/megapos-release.jks
RELEASE_KEY_ALIAS=megapos_release
RELEASE_STORE_PASSWORD=change_me_store_password
RELEASE_KEY_PASSWORD=change_me_store_password
RELEASE_KEY_VALIDITY_DAYS=9125
RELEASE_KEY_DNAME=CN=MEGAPOS,OU=Mobile,O=MEGAPOS,L=Bengaluru,ST=Karnataka,C=IN

# Test environment URL (used by all modes when APP_MODE=test)
TEST_URL=http://192.168.1.161:3000

# Production environment URLs
KIOSK_URL_LIVE=https://megapos-kiosk.vercel.app
LARGE_KIOSK_URL_LIVE=https://megapos-large-kiosk.vercel.app
POS_URL_LIVE=https://megapos-pos-kiosk.vercel.app
MOBILE_KIOSK_URL_LIVE=https://megapos-mobilekiosk.vercel.app

# Per-mode feature flags
# Enable/disable NFC (Tap to Pay) per mode.
# Modes that don't need NFC (e.g. POS) can set to false.
ENABLE_NFC_KIOSK=true
ENABLE_NFC_LARGE_KIOSK=true
ENABLE_NFC_POS=false
ENABLE_NFC_MOBILE_KIOSK=true

# Tap to Pay simulation mode: 'true' or 'false'
# When empty, defaults to true in test mode, false in live mode
TAP_TO_PAY_SIMULATED=false
