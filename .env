# ===============================================
# AI Kiosk POS - Environment Configuration
# ===============================================

# Application Mode: 'test' or 'live'
# Controls which URLs to use for each kiosk mode
APP_MODE=test

# Launch mode:
# - selection: show mode selection page
# - kiosk | large_kiosk | pos | mobile_kiosk: launch directly in that mode
KIOSK_FIXED_MODE=pos

# ===============================================
# RELEASE BUILD CONTROLS (used by ./build_release.sh)
# ===============================================
# true  -> automatically increase pubspec build number (+N) every release build.
# false -> keep current version/build number.
BUILD_RELEASE_AUTO_INCREMENT=true

# true  -> build all 4 mode APKs in one run.
# false -> build only one mode (BUILD_RELEASE_DEFAULT_MODE).
BUILD_RELEASE_ALL_APKS=true

# Mode used when BUILD_RELEASE_ALL_APKS=false
# Allowed: kiosk | large_kiosk | pos | mobile_kiosk
BUILD_RELEASE_DEFAULT_MODE=pos

# Output folder and file prefix for generated APKs
BUILD_RELEASE_OUTPUT_DIR=release_apks
BUILD_RELEASE_NAME_PREFIX=megapos

# Persistent release signing (IMPORTANT: keep same key forever for app updates)
AUTO_CREATE_RELEASE_KEYSTORE=true
RELEASE_KEYSTORE_PATH=android/app/megapos-release.jks
RELEASE_KEY_ALIAS=megapos_release
RELEASE_STORE_PASSWORD=change_me_store_password
RELEASE_KEY_PASSWORD=change_me_store_password
RELEASE_KEY_VALIDITY_DAYS=9125
RELEASE_KEY_DNAME=CN=MEGAPOS,OU=Mobile,O=MEGAPOS,L=Bengaluru,ST=Karnataka,C=IN

# Tap to Pay Simulation Mode
# Set to 'true' to use simulated payments, 'false' for real payments
# Defaults to 'true' in test mode, 'false' in live mode if not specified
TAP_TO_PAY_SIMULATED=false

# Tap to Pay Instruction Popup
# Set to 'true' to show the 5-second Tap-to-Pay popup before payment collection
# Set to 'false' to skip it and go directly to native NFC/payment screen
SHOW_TTP_INSTRUCTION_POPUP=true

# ===============================================
# TEST ENVIRONMENT URL
# ===============================================
# Single URL for all modes in test environment (local IP)
TEST_URL=http://192.168.1.54:3000

# ===============================================
# LIVE/PRODUCTION URLs (Mode-specific)
# ===============================================

# Kiosk Mode - Live URL
KIOSK_URL_LIVE=https://kiosk.megapos.app

# Large Kiosk Mode - Live URL
LARGE_KIOSK_URL_LIVE=https://largekiosk.megapos.app
# POS Mode - Live URL
POS_URL_LIVE=https://pos.megapos.app

# Mobile Kiosk Mode - Live URL
MOBILE_KIOSK_URL_LIVE=https://mobilepos.megapos.app

# ===============================================
# NOTES:
# - Change APP_MODE to 'test' to use single TEST_URL for all modes
# - Change APP_MODE to 'live' to use mode-specific LIVE URLs
# - 4 Modes: KIOSK, LARGE KIOSK, POS, MOBILE KIOSK
# - Test mode uses local IP for development
# - Live mode uses separate URLs per mode
# ===============================================
